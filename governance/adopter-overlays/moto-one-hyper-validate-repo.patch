+def validate_rom_lab(root: Path, problems: list[Problem]) -> None:
+    lab = root / "rom_lab"
+    if not lab.is_dir():
+        problems.append(Problem(lab, "missing ROM lab directory"))
+        return
+    for rel in ROM_LAB_REQUIRED:
+        path = root / rel
+        if not path.is_file():
+            problems.append(Problem(path, "missing required ROM lab file"))
+
+    profile_path = root / "rom_lab" / "device_def" / "device_profile.json"
+    try:
+        profile = load_json(profile_path)
+    except (OSError, ValueError, json.JSONDecodeError) as exc:
+        problems.append(Problem(profile_path, f"device profile is not valid JSON: {exc}"))
+        profile = {}
+    missing = ROM_LAB_PROFILE_FIELDS - set(profile)
+    if missing:
+        problems.append(Problem(profile_path, f"device profile missing fields: {', '.join(sorted(missing))}"))
+    if profile.get("stock_boot_verified") is not False:
+        problems.append(Problem(profile_path, "stock_boot_verified must remain false until a verified stock boot image exists"))
+    if profile.get("root_available") is not False:
+        problems.append(Problem(profile_path, "root_available must remain false until root is actually available"))
+
+    invariants_path = root / "governance" / "invariants.json"
+    agents_path = root / "AGENTS.md"
+    try:
+        invariants_text = invariants_path.read_text(encoding="utf-8").lower()
+    except OSError:
+        invariants_text = ""
+    try:
+        agents_text = agents_path.read_text(encoding="utf-8").lower()
+    except OSError:
+        agents_text = ""
+    for required in ("flash", "erase", "wipe", "relock", "approval"):
+        if required not in invariants_text or required not in agents_text:
+            problems.append(Problem(invariants_path, f"safety invariant docs must mention '{required}'"))
+
+    for path in root.rglob("*"):
+        if not path.is_file():
+            continue
+        if ".git" in path.parts or "__pycache__" in path.parts:
+            continue
+        if path.suffix.lower() in FORBIDDEN_BINARY_SUFFIXES:
+            problems.append(Problem(path, "forbidden firmware/image/archive artifact must not be committed"))
+        elif path.stat().st_size > MAX_REPO_FILE_BYTES:
+            problems.append(Problem(path, f"file exceeds safe repository size threshold ({MAX_REPO_FILE_BYTES} bytes)"))
+
+    script_roots = (root / "scripts", root / "rom_lab" / "scripts")
+    for script_root in script_roots:
+        if not script_root.is_dir():
+            continue
+        for path in script_root.glob("*.ps1"):
+            text = path.read_text(encoding="utf-8").lower()
+            for term in DESTRUCTIVE_SCRIPT_TERMS:
+                if term in text:
+                    problems.append(Problem(path, f"destructive command term is not allowed in execution scripts: {term.strip()}"))
+
+
@@ -627,0 +740 @@
+    validate_rom_lab(root, problems)
